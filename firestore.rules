rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email in ['krizo19@gmail.com'];
    }

    function validUrlOrEmpty(value) {
      return value == null || (value is string && (value.size() == 0 || value.matches('^https?://.+')));
    }

    function validUserData() {
      return request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 2
        && request.resource.data.displayName.size() <= 80
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email
        && (request.resource.data.role == null || (request.resource.data.role is string && request.resource.data.role.size() <= 120))
        && (request.resource.data.bio == null || (request.resource.data.bio is string && request.resource.data.bio.size() <= 600))
        && validUrlOrEmpty(request.resource.data.socialLink)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function validPostData() {
      return request.resource.data.authorId == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.authorName.size() >= 2
        && request.resource.data.authorName.size() <= 80
        && (request.resource.data.authorRole == null || (request.resource.data.authorRole is string && request.resource.data.authorRole.size() <= 120))
        && validUrlOrEmpty(request.resource.data.socialLink)
        && request.resource.data.type in ['update', 'discussion', 'notice']
        && (request.resource.data.tag == null || (request.resource.data.tag is string && request.resource.data.tag.size() <= 60))
        && request.resource.data.content is string
        && request.resource.data.content.size() >= 1
        && request.resource.data.content.size() <= 2000
        && request.resource.data.createdAt is timestamp;
    }

    function validConversationData() {
      return request.resource.data.participantIds is list
        && request.resource.data.participantIds.size() == 2
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.participantNames is map
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function isConversationParticipant(data) {
      return signedIn()
        && data.participantIds is list
        && request.auth.uid in data.participantIds;
    }

    function validMessageData(conversationId) {
      return request.resource.data.fromId == request.auth.uid
        && request.resource.data.toId is string
        && request.resource.data.fromName is string
        && request.resource.data.fromName.size() >= 2
        && request.resource.data.fromName.size() <= 80
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 1
        && request.resource.data.text.size() <= 1500
        && request.resource.data.createdAt is timestamp
        && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds is list
        && request.resource.data.toId in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
    }

    function validThreadSummary(ownerUid) {
      return request.resource.data.ownerId == ownerUid
        && request.resource.data.otherUid is string
        && request.resource.data.otherUid.size() > 0
        && request.resource.data.otherName is string
        && request.resource.data.otherName.size() >= 1
        && request.resource.data.otherName.size() <= 80
        && request.resource.data.lastMessageText is string
        && request.resource.data.lastMessageText.size() >= 0
        && request.resource.data.lastMessageText.size() <= 200
        && request.resource.data.lastSenderId is string
        && request.resource.data.updatedAt is timestamp;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isSelf(uid) && validUserData();
      allow update: if (isSelf(uid) || isAdmin())
        && validUserData()
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;

      match /threads/{threadId} {
        allow read: if isSelf(uid);
        allow create, update: if signedIn()
          && validThreadSummary(uid)
          && (request.auth.uid == uid || request.auth.uid == request.resource.data.otherUid || isAdmin());
        allow delete: if false;
      }
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if signedIn() && validPostData();
      allow update: if signedIn() && validPostData() && (resource.data.authorId == request.auth.uid || isAdmin()) && request.resource.data.authorId == resource.data.authorId;
      allow delete: if signedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    match /conversations/{conversationId} {
      allow get: if isConversationParticipant(resource.data);
      allow create: if signedIn() && validConversationData();
      allow update: if isConversationParticipant(resource.data)
        && request.resource.data.participantIds == resource.data.participantIds;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isConversationParticipant(get(/databases/$(database)/documents/conversations/$(conversationId)).data);
        allow create: if signedIn()
          && isConversationParticipant(get(/databases/$(database)/documents/conversations/$(conversationId)).data)
          && validMessageData(conversationId);
        allow update, delete: if false;
      }
    }
  }
}
